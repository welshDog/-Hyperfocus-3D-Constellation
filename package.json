{
  "name": "hyperfocus-3d-constellation",
  "version": "1.0.0",
  "type": "module",
  "description": "The world's most advanced 3D repository visualization designed for neurodivergent minds",
  "main": "app.js",
  "scripts": {
    "dev": "http-server -p 8090 -c-1",
    "postinstall": "npm run cache:cdn",
    "cache:cdn": "node tools/cache-cdn.cjs",
    "build:lighthouse": "lighthouse https://welshdog.github.io/-Hyperfocus-3D-Constellation/ --output=json --output-path=./reports/lighthouse.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "playwright test",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:contract": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/contract",
    "lint": "eslint --ext .js .",
    "lint:fix": "eslint --ext .js . --fix",
    "format": "prettier --write \"**/*.{js,html,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,html,css,md}\"",
    "audit": "npm audit --audit-level=moderate",
    "analyze": "npm run lint && npm run format:check && npm run test",
    "a11y:audit": "axe https://welshdog.github.io/-Hyperfocus-3D-Constellation/",
    "lint:selectors": "node tools/selector-contract-lint.cjs",
    "rollback": "node tools/rollback.cjs",
    "gateway:mock": "node tools/mock-gateway.cjs",
    "docs:dev": "npm --prefix docs-portal run dev",
    "docs:build": "npm --prefix docs-portal run build",
    "docs:validate": "node tools/validate-openapi.cjs"
  },
  "keywords": [
    "3d",
    "visualization",
    "github",
    "repository",
    "neurodivergent",
    "accessibility",
    "three.js",
    "web-audio-api",
    "interactive"
  ],
  "author": "Lyndz Williams",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/welshDog/-Hyperfocus-3D-Constellation.git"
  },
  "bugs": {
    "url": "https://github.com/welshDog/-Hyperfocus-3D-Constellation/issues"
  },
  "homepage": "https://github.com/welshDog/-Hyperfocus-3D-Constellation",
  "devDependencies": {
    "three": "^0.160.0",
    "http-server": "^14.1.1",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.1.5",
    "@jest/globals": "^29.7.0",
    "axe-core": "^4.8.2",
    "@playwright/test": "^1.40.1",
    "@pact-foundation/pact": "^12.1.1",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "node-fetch": "^3.3.2",
    "wait-on": "^7.2.0",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^11.4.0",
    "playwright": "^1.40.1",
    "prettier": "^3.1.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "collectCoverageFrom": [
      "audio.js",
      "ui.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "lines": 80
      }
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "always"
  }
}
